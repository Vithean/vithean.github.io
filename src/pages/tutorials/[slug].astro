---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import videosData from '../../data/videos.json';

interface Video {
  id: string;
  slug: string;
  title: string;
  url: string;
  thumbnail: string;
  thumbnailHQ?: string;
  published?: string | null;
  author?: string | null;
  description?: string;
}

interface VideoData {
  playlistUrl?: string;
  videos?: Video[];
}

export async function getStaticPaths() {
  const data = (await import('../../data/videos.json')).default as {
    videos?: Video[];
  };
  const videos = data.videos ?? [];

  return videos.map((video, i) => ({
    params: { slug: video.slug },
    props: {
      video,
      prev: i > 0 ? videos[i - 1] : null,
      next: i < videos.length - 1 ? videos[i + 1] : null,
      total: videos.length,
      position: i + 1,
    },
  }));
}

const { video, prev, next, total, position } = Astro.props as {
  video: Video;
  prev: Video | null;
  next: Video | null;
  total: number;
  position: number;
};

const data = videosData as VideoData;
const playlistUrl = data.playlistUrl;

const publishedDate = video.published
  ? new Date(video.published).toLocaleDateString(undefined, {
      year: 'numeric', month: 'long', day: 'numeric',
    })
  : null;
---

<StarlightPage
  frontmatter={{
    title: video.title,
    description: video.description?.slice(0, 160) || `Video tutorial: ${video.title}`,
    template: 'doc',
    lastUpdated: video.published ? new Date(video.published) : undefined,
    pagefind: true,
  }}
>
  <div class="video-page-header">
    <p class="video-page-eyebrow">
      Video Tutorial &middot; {position} of {total}
    </p>
  </div>

  <div class="video-player">
    <iframe
      src={`https://www.youtube-nocookie.com/embed/${video.id}?rel=0&modestbranding=1`}
      title={video.title}
      loading="lazy"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      referrerpolicy="strict-origin-when-cross-origin"
      allowfullscreen
    ></iframe>
  </div>

  {publishedDate && (
    <p class="video-meta-line">
      Published {publishedDate}
      {playlistUrl && (
        <> &middot; <a href={video.url} target="_blank" rel="noopener">Watch on YouTube</a>
        </>
      )}
    </p>
  )}

  {video.description && (
    <>
      <h2>About this video</h2>
      <div class="video-description">{video.description}</div>
    </>
  )}

  <nav class="video-nav" aria-label="Tutorial navigation">
    {prev ? (
      <a href={`/tutorials/${prev.slug}/`} class="prev">
        <div class="nav-label">← Previous</div>
        <div class="nav-title">{prev.title}</div>
      </a>
    ) : (
      <div class="placeholder"></div>
    )}

    {next ? (
      <a href={`/tutorials/${next.slug}/`} class="next">
        <div class="nav-label">Next →</div>
        <div class="nav-title">{next.title}</div>
      </a>
    ) : (
      <div class="placeholder"></div>
    )}
  </nav>

  <p style="margin-top: 2rem; text-align: center;">
    <a href="/tutorials/">← Back to all tutorials</a>
  </p>
</StarlightPage>
