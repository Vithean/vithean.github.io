---
// Featured-tutorial card for the landing page.
// Reads the latest entry from src/data/videos.json and renders a hero-style
// card with thumbnail, NEW badge (if recent), title, description, and CTA.
import videosData from '../data/videos.json';

interface Video {
  id: string;
  slug: string;
  title: string;
  thumbnail: string;
  thumbnailHQ?: string;
  published?: string | null;
  description?: string;
}

interface VideoData { videos?: Video[]; playlistUrl?: string }

const data = videosData as VideoData;
const videos = data.videos ?? [];
const featured = videos[0] ?? null;

const NEW_WINDOW_DAYS = 30;
const isRecent = (iso?: string | null) => {
  if (!iso) return false;
  const age = Date.now() - new Date(iso).getTime();
  return age < NEW_WINDOW_DAYS * 24 * 60 * 60 * 1000;
};

const published = featured?.published
  ? new Date(featured.published).toLocaleDateString(undefined, {
      year: 'numeric', month: 'long', day: 'numeric',
    })
  : null;

const shortDescription = featured?.description
  ? featured.description.split('\n').filter(Boolean).slice(0, 2).join(' ').slice(0, 220) +
    (featured.description.length > 220 ? '…' : '')
  : null;
---

{featured && (
  <section class="featured-video" aria-label="Latest video tutorial">
    <div class="featured-eyebrow">
      <span class="featured-pill">
        {isRecent(featured.published) && <span class="dot" aria-hidden="true"></span>}
        Latest video tutorial
      </span>
      {published && <span class="featured-date">{published}</span>}
    </div>

    <a class="featured-card" href={`/tutorials/${featured.slug}/`} aria-label={`Watch: ${featured.title}`}>
      <div class="featured-thumb">
        <img src={featured.thumbnailHQ || featured.thumbnail} alt={featured.title} loading="eager" />
        <div class="featured-play" aria-hidden="true">
          <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
            <circle cx="40" cy="40" r="40" fill="rgba(111, 48, 117, 0.92)"/>
            <path d="M32 24 L58 40 L32 56 Z" fill="white"/>
          </svg>
        </div>
      </div>
      <div class="featured-body">
        <h3 class="featured-title">{featured.title}</h3>
        {shortDescription && <p class="featured-description">{shortDescription}</p>}
        <span class="featured-cta">
          Watch this tutorial
          <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
            <path d="M3 8 H13 M9 4 L13 8 L9 12" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </div>
    </a>
  </section>
)}

<style>
  .featured-video {
    margin: 2.5rem 0 3rem;
  }

  .featured-eyebrow {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.9rem;
    font-size: 0.85rem;
  }

  .featured-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    background: var(--sl-color-accent-low);
    color: var(--sl-color-accent);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-size: 0.72rem;
  }

  .dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--vithean-purple);
    box-shadow: 0 0 0 0 var(--vithean-purple);
    animation: pulse 2.2s ease-out infinite;
  }
  @keyframes pulse {
    0%   { box-shadow: 0 0 0 0   color-mix(in srgb, var(--vithean-purple) 60%, transparent); }
    70%  { box-shadow: 0 0 0 10px color-mix(in srgb, var(--vithean-purple) 0%,  transparent); }
    100% { box-shadow: 0 0 0 0   color-mix(in srgb, var(--vithean-purple) 0%,  transparent); }
  }

  .featured-date {
    color: var(--sl-color-gray-3);
  }

  .featured-card {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
    gap: 0;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 18px;
    overflow: hidden;
    background: var(--sl-color-gray-7);
    text-decoration: none !important;
    color: inherit !important;
    transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
  }

  @media (max-width: 50rem) {
    .featured-card { grid-template-columns: 1fr; }
  }

  .featured-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 50px -20px rgba(111, 48, 117, 0.4);
    border-color: var(--vithean-purple-soft);
  }

  .featured-thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    background: #000;
    overflow: hidden;
  }

  .featured-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: none !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    margin: 0 !important;
    display: block;
    transition: transform 0.4s ease;
  }

  .featured-card:hover .featured-thumb img {
    transform: scale(1.04);
  }

  .featured-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.22s ease;
  }

  .featured-card:hover .featured-play {
    transform: scale(1.08);
  }

  .featured-play svg {
    width: 84px;
    height: 84px;
    filter: drop-shadow(0 6px 16px rgba(0, 0, 0, 0.45));
  }

  .featured-body {
    padding: 1.6rem 1.8rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.6rem;
  }

  .featured-title {
    margin: 0;
    font-size: clamp(1.15rem, 1.8vw, 1.45rem);
    line-height: 1.3;
    color: var(--sl-color-white);
    letter-spacing: -0.01em;
  }

  .featured-description {
    margin: 0;
    color: var(--sl-color-gray-2);
    font-size: 0.95rem;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured-cta {
    margin-top: 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--vithean-purple);
    font-weight: 600;
    font-size: 0.95rem;
    transition: gap 0.22s ease;
  }

  [data-theme='dark'] .featured-cta {
    color: var(--vithean-purple-soft);
  }

  .featured-card:hover .featured-cta {
    gap: 0.7rem;
  }

  [data-theme='dark'] .featured-card {
    background: rgba(255, 255, 255, 0.02);
    border-color: rgba(255, 255, 255, 0.08);
  }
</style>
